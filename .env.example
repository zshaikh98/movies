# TMDB API credentials — copy this file to .env and fill in your values.
# Get these from https://www.themoviedb.org/settings/api
#
# The v4 read access token is preferred (Bearer auth).
# The v3 API key is kept for endpoints/tools that still want it.

TMDB_READ_ACCESS_TOKEN=your_v4_read_access_token_here
TMDB_API_KEY=your_v3_api_key_here

# Optional: image base URL + default poster size for building poster URLs.
# Full URL = TMDB_IMAGE_BASE_URL + size + poster_path
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p/
TMDB_POSTER_SIZE=w500
